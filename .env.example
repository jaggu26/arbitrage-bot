# Railway/Render Environment Variables
# Add your tokens here and set as environment variables in the deployment platform

PORT=4000
NODE_ENV=production

# RezorEx Exchange Tokens
REZOREX_ACCESS_TOKEN=your_rezorex_access_token_here
REZOREX_REFRESH_TOKEN=your_rezorex_refresh_token_here

# CryptoForce Exchange Tokens
CRYPTOFORCE_ACCESS_TOKEN=your_cryptoforce_access_token_here
CRYPTOFORCE_REFRESH_TOKEN=your_cryptoforce_refresh_token_here